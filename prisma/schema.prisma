generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  client
  business
  admin
}

enum ReviewTargetType {
  studio
  instructor
  class
}

enum SubscriptionRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum PaymentStatus {
  pending
  paid
  failed
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  passwordHash  String?
  role          Role      @default(client)
  image         String?
  /// Set when the business user dismisses the dashboard onboarding modal (shown once).
  dashboardOnboardingDismissedAt DateTime?
  /// Setup guide widget: closed to sidebar vs floating (bottom-right).
  dashboardSetupGuideDocked      Boolean @default(false)
  /// Setup guide widget: minimized to chip vs expanded panel.
  dashboardSetupGuideMinimized   Boolean @default(false)

  accounts       Account[]
  sessions       Session[]
  businesses     Business[]
  reviewsWritten Review[]  @relation("ReviewAuthor")
  favorites      Favorite[]
  classAttendances UserClassAttendance[]
  bookings       Booking[]
  scheduleEntryBookings ScheduleEntryBooking[]
}

/// A client user’s completed visit to a scheduled class (used for profile history and spend summary).
model UserClassAttendance {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  yogaClassId String
  yogaClass   YogaClass @relation(fields: [yogaClassId], references: [id], onDelete: Cascade)
  attendedAt  DateTime  @default(now())

  @@unique([userId, yogaClassId])
  @@index([userId, attendedAt(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id          String   @id @default(cuid())
  ownerUserId String   @unique
  owner       User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studios Studio[]
}

model Studio {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  address     String
  lat         Float?
  lng         Float?
  description String
  phone       String
  email       String
  website     String?

  // Supabase Storage public URLs
  images String[]

  amenitiesParking         Boolean @default(false)
  amenitiesShower          Boolean @default(false)
  amenitiesChangingRoom    Boolean @default(false)
  amenitiesEquipmentRental Boolean @default(false)

  rating      Float @default(0)
  reviewCount Int   @default(0)

  yogaTypes String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructors   Instructor[]
  classes       YogaClass[]
  schedule      ScheduleEntry[]
  subscription          StudioSubscription?
  subscriptionRequests  SubscriptionRequest[]
  favorites             Favorite[]
}

model Instructor {
  id               String   @id @default(cuid())
  studioId         String
  studio           Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  name             String
  photo            String   @default("")
  bio              String
  yogaStyle        String[] @default([])
  experienceLevel  String
  rating           Float    @default(0)

  classes  YogaClass[]
  schedule ScheduleEntry[]
}

model YogaClass {
  id                  String   @id @default(cuid())
  studioId            String
  studio              Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  instructorId        String
  instructor          Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  name                String
  date                DateTime @db.Date
  startTime           String
  endTime             String
  maxCapacity         Int
  enrolled            Int      @default(0)
  price               Float
  yogaType            String
  difficulty          String
  cancellationPolicy  String
  waitingList         String[] @default([])

  attendances UserClassAttendance[]
  bookings    Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  yogaClassId String
  yogaClass   YogaClass @relation(fields: [yogaClassId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  payment Payment?

  @@unique([userId, yogaClassId])
  @@index([yogaClassId])
}

model Payment {
  id                      String        @id @default(cuid())
  bookingId               String?       @unique
  booking                 Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  scheduleEntryBookingId  String?       @unique
  scheduleEntryBooking    ScheduleEntryBooking? @relation(fields: [scheduleEntryBookingId], references: [id], onDelete: Cascade)
  status                  PaymentStatus @default(pending)
  amount                  Int
  currency                String        @default("eur")
  stripeCheckoutSessionId String        @unique
  stripePaymentIntentId   String?       @unique
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model ScheduleEntry {
  id           String   @id @default(cuid())
  studioId     String
  studio       Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  className   String
  yogaType    String
  difficulty  String
  day         String
  startTime   String
  endTime     String
  maxCapacity Int
  enrolled    Int      @default(0)
  price       Float
  isRecurring Boolean  @default(true)

  bookings ScheduleEntryBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduleEntryBooking {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleEntryId String
  scheduleEntry   ScheduleEntry @relation(fields: [scheduleEntryId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  payment Payment?

  @@unique([userId, scheduleEntryId])
  @@index([scheduleEntryId])
}

model Review {
  id                String           @id @default(cuid())
  targetType        ReviewTargetType
  targetId          String
  rating            Int
  text              String
  date              DateTime         @db.Date

  authorUserId      String?
  author            User?            @relation("ReviewAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorDisplayName String
  authorEmail       String?

  createdAt DateTime @default(now())
}

model StudioSubscription {
  id                     String  @id @default(cuid())
  studioId               String  @unique
  studio                 Studio  @relation(fields: [studioId], references: [id], onDelete: Cascade)
  hasMonthlySubscription Boolean @default(false)
  monthlyPrice           Float?
  subscriptionNote       String?
}

model SubscriptionRequest {
  id           String                     @id @default(cuid())
  studioId     String
  studio       Studio                     @relation(fields: [studioId], references: [id], onDelete: Cascade)
  status       SubscriptionRequestStatus  @default(PENDING)
  name         String
  monthlyPrice Float
  includes     String                     @db.Text
  adminNote    String?                    @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studioId, status])
  @@index([status, createdAt])
}

model RecentEnrollment {
  id              String   @id @default(cuid())
  userDisplayName String
  className       String
  studioName      String
  enrolledAt      DateTime
}

model Favorite {
  userId   String
  studioId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  studio   Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, studioId])
}
